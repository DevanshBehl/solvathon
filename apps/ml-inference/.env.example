# HMS ML Inference Service — Environment Configuration
# Copy to .env and edit as needed

# Server
DETECT_HOST=0.0.0.0
DETECT_PORT=8010

# Models — relative to apps/ml-inference/ → repo root ml/models/
MODELS_ROOT=../../ml/models

# Inference
INFER_DEVICE=auto
TARGET_FPS=30
FRAME_SKIP=1
MIN_SLEEP_TIME=0.001
RAW_INFERENCE_MODE=true
CACHE_ENABLED_MODELS=true

# Confidence thresholds (PRD §11.1)
CONF_THRESHOLD_ACTION=0.55
CONF_THRESHOLD_OBJECT=0.45
CONF_THRESHOLD_WEAPON=0.60

# Flagging (PRD §5.2)
FLAG_ANIMAL_DURATION_SEC=60
FLAG_LOITERING_DURATION_SEC=120
FLAG_RESOLVE_HYSTERESIS_SEC=30

# Model toggles
ENABLE_MODEL1=true
ENABLE_MODEL2=true
ENABLE_MODEL3=true
ENABLE_MODEL4=true

# Inference FPS target (frames/sec sent to bridge)
INFERENCE_FPS=5

# Storage
STORAGE_ROOT=storage
SNAP_MAX_PER_EVENT=10
