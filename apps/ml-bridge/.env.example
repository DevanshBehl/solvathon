# HMS ML Bridge Service Configuration

# HMS Web Application URL
HMS_API_URL=http://localhost:3000

# HMS Media Server WebSocket URL
HMS_WS_URL=ws://localhost:4000

# Intrusion-suite detection service WebSocket URL
DETECTION_WS_URL=ws://localhost:8010/ws/detections

# Intrusion-suite detection service HTTP API URL
DETECTION_API_URL=http://localhost:8010

# API key for authenticating with HMS /api/alerts/ml endpoint
ML_API_KEY=hms-ml-key-2026

# Camera ID this bridge instance is handling
CAMERA_ID=default
