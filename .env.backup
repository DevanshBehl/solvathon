# ========================================
# Hostel Monitor — Environment Variables
# ========================================

# PostgreSQL connection string
DATABASE_URL="postgresql://devanshbehl:devansh@localhost:5432/hostel_monitor?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# NextAuth.js
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Media Server WebSocket URL (used by browser client)
NEXT_PUBLIC_MEDIA_SERVER_WS_URL="ws://localhost:4000"

# ML Service API Key (for webhook authentication)
ML_API_KEY="ml-service-api-key-change-in-production"

# mediasoup — Announced IP
# Set this to the LAN IP or public IP of the machine running media-server.
# Browsers need to reach this IP to establish WebRTC connections.
# For local development, use your machine's LAN IP (e.g., 192.168.1.100).
# Do NOT use 127.0.0.1 unless testing from the same machine.
ANNOUNCED_IP="127.0.0.1"

# mediasoup — RTP port range
# These ports must be open in your firewall for WebRTC media traffic.
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
